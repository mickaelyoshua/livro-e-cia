# PostgreSQL (used by docker-compose and DATABASE_URL)
POSTGRES_USER=livro_cia
POSTGRES_PASSWORD=livro_cia_dev
POSTGRES_DB=livro_cia_db

# SQLx / Axum
DATABASE_URL=postgresql://livro_cia:livro_cia_dev@localhost:5432/livro_cia_db

# Server
HOST=127.0.0.1
PORT=8000

# JWT (minimum 32 bytes, hex-encoded)
JWT_SECRET=change_me_to_a_random_hex_string_at_least_32_bytes

# Cookie encryption (64 bytes, hex-encoded)
COOKIE_SECRET_KEY=change_me_to_a_random_hex_string_64_bytes_long_for_cookie_encryption_key

# Logging
RUST_LOG=info

# Environment (development | production)
APP_ENV=development
