# PostgreSQL Configuration
POSTGRES_USER=livro_cia_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=livro_cia_db

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Backend Connection Strings
DATABASE_URL=postgresql://livro_cia_user:CHANGE_ME@localhost:5432/livro_cia_db
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Backend Configuration
JWT_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET
ROCKET_PORT=8000
RUST_LOG=info

# CORS Configuration
CORS_ORIGINS=http://localhost:8080

# Email Configuration (optional - has defaults)
EMAIL_FROM_ADDRESS=noreply@livroecia.local
EMAIL_FROM_NAME="Livro e Cia"
APP_BASE_URL=http://localhost:8080

# Email Provider: "mock" (development) or "smtp" (production)
EMAIL_PROVIDER=mock

# SMTP Configuration (required when EMAIL_PROVIDER=smtp)
# For Gmail: host=smtp.gmail.com, port=587, use app password
# For Outlook: host=smtp.office365.com, port=587
# For local testing with MailHog: host=localhost, port=1025, SMTP_USE_TLS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Security Notes:
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate passwords: openssl rand -base64 32
# 3. Generate JWT secret: openssl rand -hex 32
# 4. Never commit .env to git (add to .gitignore)
