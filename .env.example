# ============================================
# ENVIRONMENT
# ============================================
# Options: development, staging, production
APP_ENV=development

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_USER=livro_cia_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=livro_cia_db

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ============================================
# Backend Connection Strings
# ============================================
# Development (no SSL)
DATABASE_URL=postgresql://livro_cia_user:CHANGE_ME@localhost:5432/livro_cia_db
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Production requires SSL:
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# ============================================
# Security
# ============================================
JWT_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET

# ============================================
# Rocket Server (override Rocket.toml)
# ============================================
ROCKET_PORT=8000
ROCKET_ADDRESS=127.0.0.1

# ============================================
# CORS
# ============================================
# Development default: http://localhost:8080
# Production: MUST be set explicitly
CORS_ORIGINS=http://localhost:8080

# ============================================
# Email
# ============================================
EMAIL_FROM_ADDRESS=noreply@livroecia.local
EMAIL_FROM_NAME="Livro e Cia"
APP_BASE_URL=http://localhost:8080

# Provider: "mock" (dev) or "smtp" (prod)
# Production enforces smtp
EMAIL_PROVIDER=mock

# SMTP (required in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# ============================================
# Logging
# ============================================
RUST_LOG=info

# ============================================
# PRODUCTION REQUIREMENTS
# ============================================
# 1. APP_ENV=production
# 2. DATABASE_URL with sslmode=require
# 3. CORS_ORIGINS explicitly set
# 4. EMAIL_PROVIDER=smtp
# 5. Redis must be running (fail-secure)

# ============================================
# SECURITY NOTES
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate passwords: openssl rand -base64 32
# 3. Generate JWT secret: openssl rand -hex 32
# 4. Never commit .env to git (add to .gitignore)
